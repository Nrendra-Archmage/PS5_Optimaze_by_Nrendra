<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style TargetType="CheckBox">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Height" Value="55" />
        <Setter Property="Margin" Value="25,0,10,0" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid Background="Transparent">
                            <Grid Margin="15,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    x:Name="CheckOff"
                                    Grid.Column="1"
                                    Width="100"
                                    Height="30"
                                    Margin="0,0,-30,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    CornerRadius="0">
                                    <Viewbox>
                                        <Image
                                            Margin="0,0,0,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            RenderOptions.BitmapScalingMode="Fant"
                                            Source="{ThemeFile 'Images/PS5/CheckBox/CheckOff.png'}" />
                                    </Viewbox>
                                </Border>
                                <Border
                                    x:Name="CheckOn"
                                    Grid.Column="1"
                                    Width="100"
                                    Height="30"
                                    Margin="0,0,-30,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    CornerRadius="0"
                                    Visibility="Collapsed">
                                    <Viewbox>
                                        <Image
                                            Margin="0,0,0,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            RenderOptions.BitmapScalingMode="Fant"
                                            Source="{ThemeFile 'Images/PS5/CheckBox/CheckOn.png'}" />
                                    </Viewbox>
                                </Border>
                                <TextBlock
                                    Grid.Column="0"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    FontFamily="Segoe UI SemiLight"
                                    FontSize="24"
                                    Foreground="White"
                                    TextTrimming="WordEllipsis">
                                    <ContentPresenter RecognizesAccessKey="True" />
                                </TextBlock>
                            </Grid>
                            <Border
                                x:Name="MainBorder"
                                Margin="0"
                                BorderThickness="3"
                                CornerRadius="15"
                                Opacity="0"
                                Style="{DynamicResource PS5Border}"
                                Tag="False"
                                Visibility="Collapsed" />
                            <Border
                                x:Name="FlashMenuBorder"
                                Margin="5"
                                CornerRadius="10"
                                Style="{DynamicResource PS5Cover}"
                                Tag="False"
                                Visibility="Collapsed" />

                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckOn" Property="Visibility" Value="Visible" />
                            <Setter TargetName="CheckOff" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="MainBorder" Property="Tag" Value="True" />
                            <Setter TargetName="FlashMenuBorder" Property="Tag" Value="True" />
                            <Setter TargetName="MainBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="FlashMenuBorder" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="Tag" Value="True" />
                            <Setter TargetName="FlashMenuBorder" Property="Tag" Value="True" />
                            <Setter TargetName="MainBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="FlashMenuBorder" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

