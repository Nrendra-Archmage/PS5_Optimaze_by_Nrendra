                                Background="{DynamicResource PS5Button}"
                                CornerRadius="25" />
                                <Grid>
                                    <Grid.OpacityMask>
                                        <VisualBrush Visual="{Binding ElementName=mask}" />
                                    </Grid.OpacityMask>

                                </Grid>
                                <Image
                                x:Name="SourceGames"
                                Height="80"
                                Margin="0,0,0,10"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RenderOptions.BitmapScalingMode="Fant"
                                Source="{ThemeFile 'Images/PS5/ButtonsIcon/PS5Plus.png'}" />
                                <Border
                                x:Name="MainBorder"
                                Margin="-12"
                                BorderThickness="6"
                                CornerRadius="31"
                                Opacity="1"
