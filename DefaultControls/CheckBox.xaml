    <Style x:Key="PS5LoginButton" TargetType="ToggleButton">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <ControlTemplate.Resources>
                        <Storyboard
                            x:Key="Circle1"
                            BeginTime="0:0:1"
                            FillBehavior="Stop"
                            RepeatBehavior="Forever">
                            <DoubleAnimation
                                Storyboard.TargetName="CircleBorder1"
                                Storyboard.TargetProperty="Width"
                                From="100"
                                To="300"
                                Duration="0:0:1.5" />
                            <DoubleAnimation
                                Storyboard.TargetName="CircleBorder1"
                                Storyboard.TargetProperty="Height"
                                From="100"
                                To="300"
                                Duration="0:0:1.5" />
                            <DoubleAnimation
                                Storyboard.TargetName="CircleBorder1"
                                Storyboard.TargetProperty="Opacity"
                                From="0"
                                To="1"
                                Duration="0:0:0.2" />
                            <DoubleAnimation
                                BeginTime="0:0:0.2"
                                Storyboard.TargetName="CircleBorder1"
                                Storyboard.TargetProperty="Opacity"
                                From="1"
                                To="0"
                                Duration="0:0:1.3" />
                        </Storyboard>
                        <Storyboard
                            x:Key="Circle2"
                            BeginTime="0:0:1.5"
                            FillBehavior="Stop"
                            RepeatBehavior="Forever">
                            <DoubleAnimation
                                Storyboard.TargetName="CircleBorder2"
                                Storyboard.TargetProperty="Width"
                                From="100"
                                To="300"
                                Duration="0:0:1.5" />
                            <DoubleAnimation
                                Storyboard.TargetName="CircleBorder2"
                                Storyboard.TargetProperty="Height"
                                From="100"
                                To="300"
                                Duration="0:0:1.5" />
                            <DoubleAnimation
                                Storyboard.TargetName="CircleBorder2"
                                Storyboard.TargetProperty="Opacity"
                                From="0"
                                To="1"
                                Duration="0:0:0.2" />
                            <DoubleAnimation
                                BeginTime="0:0:0.2"
                                Storyboard.TargetName="CircleBorder2"
                                Storyboard.TargetProperty="Opacity"
                                From="1"
                                To="0"
                                Duration="0:0:1.3" />
                        </Storyboard>
                    </ControlTemplate.Resources>
                    <Grid
                        x:Name="AnimIntroLogo"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5"
                        Tag="{DynamicResource PS5LogoProfile}">

                        <Border
                            x:Name="CircleBorder1"
                            Width="0"
                            Height="0"
                            BorderBrush="White"
                            CornerRadius="250"
                            Opacity="0"
                            Tag="{DynamicResource PS5LogoProfile}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderThickness" Value="5" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True">
                                            <Setter Property="BorderThickness" Value="1" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <Border
                            x:Name="CircleBorder2"
                            Width="0"
                            Height="0"
                            BorderBrush="White"
                            CornerRadius="250"
                            Opacity="0"
                            Tag="{DynamicResource PS5LogoProfile}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderThickness" Value="5" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True">
                                            <Setter Property="BorderThickness" Value="1" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Opacity" Value="1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True">
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="3" ScaleY="3" />
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Opacity" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Grid.Loaded">
                            <BeginStoryboard Storyboard="{StaticResource Circle1}" />
                            <BeginStoryboard Storyboard="{StaticResource Circle2}" />
                        </EventTrigger>
                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding ElementName=Intro, Path=Visibility}" Value="Collapsed"/>
                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="False"/>
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.Setters>
                    <Setter Property="IsChecked" Value="True" />
                </MultiDataTrigger.Setters>
            </MultiDataTrigger>
            <DataTrigger Binding="{Binding ElementName=SetupScreen, Path=Visibility}" Value="Visible">
                <Setter Property="Focusable" Value="False" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PS5TrailerTiles" TargetType="CheckBox">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid RenderTransformOrigin="0.5,0">
                        <TextBlock
                            x:Name="PlayTrailer"
                            Margin="10"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            FontFamily="{StaticResource FontIcoFont}"
                            FontSize="32"
                            Foreground="White"
                            Text="&#xeca7;">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="50" />
                            </TextBlock.Effect>
                        </TextBlock>

                        <TextBlock
    x:Name="MuteTrailer"
    Margin="15"
    HorizontalAlignment="Right"
    VerticalAlignment="Bottom"
    FontFamily="{StaticResource FontIcoFont}"
    FontSize="24" Visibility="Collapsed"
    Foreground="White"
    Text="&#xecb8;">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="50" />
                            </TextBlock.Effect>
                        </TextBlock>

                        <Border
                            x:Name="MainBorder"
                            Margin="-6"
                            BorderThickness="3"
                            CornerRadius="21"
                            Opacity="1"
                            Style="{DynamicResource PS5Border}"
                            Tag="False"
                            Visibility="Hidden">
                            <Border.CacheMode>
                                <BitmapCache
                                    EnableClearType="False"
                                    RenderAtScale="1"
                                    SnapsToDevicePixels="False" />
                            </Border.CacheMode>
                        </Border>
                        <Border
                            x:Name="FlashBorder"
                            Margin="0"
                            CornerRadius="15"
                            Opacity="1"
                            Style="{DynamicResource PS5Cover}"
                            Tag="False"
                            Visibility="Hidden">
                            <Border.CacheMode>
                                <BitmapCache
                                    EnableClearType="False"
                                    RenderAtScale="1"
                                    SnapsToDevicePixels="False" />
                            </Border.CacheMode>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="PlayTrailer" Property="Text" Value="&#xecb1;" />
                        </Trigger>
                        <DataTrigger Binding="{Binding ElementName=PART_ElemGameDetails, Path=Visibility}" Value="Collapsed">
                            <Setter Property="IsChecked" Value="False" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ElementName=ExtraMetadataLoader_VideoLoaderControl_NoControls_Sound, Path=Content.IsPlayerMuted}" Value="True">
                            <Setter TargetName="MuteTrailer" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="MainBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="MainBorder" Property="Tag" Value="True" />
                            <Setter TargetName="FlashBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="FlashBorder" Property="Tag" Value="True" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="False">
                            <Setter Property="IsChecked" Value="False" />
                        </Trigger>
                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PS5ItemStyleDummyPlus" TargetType="CheckBox">
