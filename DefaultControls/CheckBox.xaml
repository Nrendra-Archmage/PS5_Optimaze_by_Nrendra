                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding ElementName=PS5ExploreButtonDummy, Path=IsChecked}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ElementName=PS5StoreButtonDummy, Path=IsChecked}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ElementName=PS5MoreGamesButtonDummy, Path=IsChecked}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ElementName=PlayButton, Path=IsKeyboardFocusWithin}" Value="True">
                                    <Setter Property="Focusable" Value="False" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ElementName=OptionButton, Path=IsKeyboardFocusWithin}" Value="True">
                                    <Setter Property="Focusable" Value="False" />
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
