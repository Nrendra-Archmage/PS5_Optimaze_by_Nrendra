<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    mc:Ignorable="d">


    <!-- ExtraMetadata Playnite path -->
    <sys:String x:Key="ExtraMetadataPath">E:\Playnite</sys:String>

    <!-- PS5 Toggles -->
    <sys:Boolean x:Key="WelcomeLog">False</sys:Boolean>
    <sys:Boolean x:Key="AllFilters">False</sys:Boolean>
    <sys:Boolean x:Key="FiltersImages">False</sys:Boolean>
    <sys:Boolean x:Key="MediaVisibility">True</sys:Boolean>
    <sys:Boolean x:Key="TrailerOrMicro">False</sys:Boolean>
    <!-- Toggle True/False Steam Game Screenshots for supported games with steam store link -->
    <sys:Boolean x:Key="MediaScreenshots">True</sys:Boolean>
    <sys:Boolean x:Key="FullscreenMediaScreenshots">True</sys:Boolean>
    <!-- Toggle True/False Screenshot Visualiser Plugin -->
    <sys:Boolean x:Key="VisualiserScreenshots">True</sys:Boolean>
    <sys:Boolean x:Key="FullscreenVisualiserScreenshots">True</sys:Boolean>
    <!-- Toggle True/False Intro Video settings -->
    <sys:Boolean x:Key="Intro30th">False</sys:Boolean>
    <sys:Boolean x:Key="IntroVideo">True</sys:Boolean>
    <sys:Boolean x:Key="IntroVideo4k">False</sys:Boolean>
    <sys:Boolean x:Key="PressButton">True</sys:Boolean>
    <sys:Boolean x:Key="PressPSbuttonTitle">False</sys:Boolean>
    <sys:Boolean x:Key="PS5LogoProfile">False</sys:Boolean>
    <sys:Double x:Key="IntroVolume">0.5</sys:Double>
    <!-- Toggle True/False Micro Trailer as Background -->
    <sys:Boolean x:Key="MicroTrailerBackground">False</sys:Boolean>
    <sys:TimeSpan x:Key="MicroTrailerTime">00:00:04</sys:TimeSpan>
    <!-- Set Settings Menu header text -->
    <sys:String x:Key="MenuHeaderText">PS5reborn</sys:String>
    <!-- Explore Panel settings -->
    <sys:Boolean x:Key="ExplorePanel">True</sys:Boolean>
    <sys:Boolean x:Key="ExploreVideo">False</sys:Boolean>
    <sys:Double x:Key="ExploreVideoOverlay">0.5</sys:Double>
    <sys:String x:Key="WelcomeBack">Welcome back, Playnite User</sys:String>
    <sys:Boolean x:Key="WelcomeSwitch1">False</sys:Boolean>
    <sys:Boolean x:Key="WelcomeSwitch2">False</sys:Boolean>
    <sys:Boolean x:Key="WelcomeSwitch3">False</sys:Boolean>
    <sys:Boolean x:Key="Welcome0">True</sys:Boolean>
    <sys:Boolean x:Key="Welcome1">True</sys:Boolean>
    <sys:Boolean x:Key="Welcome2">True</sys:Boolean>
    <sys:Boolean x:Key="Welcome3">True</sys:Boolean>
    <sys:Boolean x:Key="Welcome4">True</sys:Boolean>
    <sys:Boolean x:Key="Welcome5">True</sys:Boolean>
    <sys:Boolean x:Key="Welcome6">True</sys:Boolean>
    <sys:Boolean x:Key="Welcome7">True</sys:Boolean>
    <!-- CC settings -->
    <sys:Boolean x:Key="DummyCenter">False</sys:Boolean>
    <sys:Boolean x:Key="HidePower1">False</sys:Boolean>
    <sys:Boolean x:Key="HidePower2">False</sys:Boolean>
    <sys:Boolean x:Key="HidePower3">False</sys:Boolean>
    <sys:Boolean x:Key="HidePower4">False</sys:Boolean>
    <sys:Boolean x:Key="HidePower5">False</sys:Boolean>
    <!-- Other settings -->
    <sys:Boolean x:Key="MiniDesc">True</sys:Boolean>
    <sys:Boolean x:Key="FriendsWhoPlay">True</sys:Boolean>
    <sys:Boolean x:Key="StarRating">True</sys:Boolean>
    <sys:Boolean x:Key="StarRatingBackground">True</sys:Boolean>
    <sys:Boolean x:Key="InstalledLabel">False</sys:Boolean>
    <sys:Boolean x:Key="PSStore">True</sys:Boolean>
    <sys:Boolean x:Key="FocusStore">True</sys:Boolean>
    <sys:Boolean x:Key="PSPlus">True</sys:Boolean>
    <sys:Boolean x:Key="FocusPlus">True</sys:Boolean>
    <sys:Boolean x:Key="BigCovers">False</sys:Boolean>
    <sys:Boolean x:Key="CoverAnims">True</sys:Boolean>
    <sys:Boolean x:Key="CoverSource">False</sys:Boolean>
    <sys:Boolean x:Key="CoverSourceTitle">True</sys:Boolean>
    <sys:String x:Key="CustomMedia">Media</sys:String>
    <sys:Boolean x:Key="LegalInfo">True</sys:Boolean>
    <sys:Double x:Key="ItemCount">10</sys:Double>
    <!-- PS5 Play/Install Button Suffix Label Localization (Play/Install XXXX) -->
    <sys:String x:Key="Game">Game</sys:String>
    <!-- PS5 Start App Button Label Localization -->
    <sys:String x:Key="Start">Launch</sys:String>
    <!-- PS5 Store Custom Items Text -->
    <sys:String x:Key="StoreGameName">Elden Ring Nightreign</sys:String>
    <sys:String x:Key="StoreItem1">Get ready for 15 days of PlayStation deals, PS Plus member offers, community events and more.</sys:String>
    <sys:String x:Key="StoreItem1Media">Stream and Download your favorite movies, TV shows and Originals on Disney+</sys:String>
    <sys:String x:Key="StoreItem2">Hunt down the Night Lords of Limveld in a co-op survival adventure set within the Elden Ring universe. Out now on PS5 and PS4</sys:String>
    <sys:String x:Key="StoreItem3">Some heroes are build different</sys:String>
    <sys:String x:Key="StoreItem4">NBA 2K25 Season 3 is here</sys:String>
    <sys:String x:Key="StoreItem5">Witness Play Unleashed</sys:String>
    <sys:String x:Key="StoreItem6">Discover PlayStation Plus</sys:String>
    <!-- PS5 Welcome Custom Items Text -->
    <sys:String x:Key="WelcomeController">Xbox 360 Wireless Controller</sys:String>
    <sys:String x:Key="WelcomeSpace">80.5 GB</sys:String>
    <sys:String x:Key="WelcomeWishGameName">Grand Theft Auto VI</sys:String>
    <sys:String x:Key="WelcomePlusGame">Black Myth Wukong</sys:String>
    <sys:String x:Key="WelcomeFriendsOnlineCount">69</sys:String>
    <!-- PS5 Profile Selection Text -->
    <sys:String x:Key="ProfileWelcome1">Welcome Back to Playnite</sys:String>
    <sys:String x:Key="ProfileName">Playnite User</sys:String>
    <!-- PS5 Plus Custom Items Text -->
    <sys:String x:Key="PlusItem1">Discover all new plan options, benefits, games and more.</sys:String>
    <sys:String x:Key="PlusPremiumText">Premium</sys:String>

    <!-- PS5 Colors -->
    <Color x:Key="BorderDark">#252e33</Color>
    <Color x:Key="BorderLight">#737b91</Color>
    <Color x:Key="PS5Trophies">#191d22</Color>
    <Color x:Key="PS5Basic">#14181e</Color>
    <Color x:Key="PS5BasicG1">#30343a</Color>
    <Color x:Key="PS5BasicG2">#1a1d24</Color>
    <Color x:Key="PS5MiniTile">#99000000</Color>


    <Color x:Key="PS5Tile">#14181e</Color>
    <Color x:Key="PS5TrophiesG1">#30343a</Color>
    <Color x:Key="PS5TrophiesG2">#1a1d24</Color>
    

    <SolidColorBrush x:Key="PS5TileBackground" Color="{DynamicResource PS5Tile}"/>
    <SolidColorBrush x:Key="PS5MiniTileBackground" Color="{DynamicResource PS5MiniTile}"/>
    <SolidColorBrush x:Key="PS5TrophiesBG" Color="{DynamicResource PS5Trophies}"/>

    <LinearGradientBrush x:Key="PS5TileGradient" StartPoint="0,1" EndPoint="1,0" >
        <GradientStop Color="{DynamicResource PS5TrophiesG1}" Offset="0"/>
        <GradientStop Color="{DynamicResource PS5TrophiesG2}" Offset="0.6"/>
        <GradientStop Color="{DynamicResource PS5TrophiesG2}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PS5BasicGradient" StartPoint="0,1" EndPoint="1,0" >
        <GradientStop Color="{DynamicResource PS5BasicG1}" Offset="0"/>
        <GradientStop Color="{DynamicResource PS5BasicG2}" Offset="0.6"/>
        <GradientStop Color="{DynamicResource PS5BasicG2}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PS5Button" StartPoint="0,1" EndPoint="1,0" >
        <GradientStop Color="#BF222222" Offset="0"/>
        <GradientStop Color="#BF111111" Offset="0.2"/>
        <GradientStop Color="#BF111111" Offset="0.8"/>
        <GradientStop Color="#BF222222" Offset="1"/>
    </LinearGradientBrush>

    <!-- Hidden experimental PS5 toggles-->

    <!-- Toggle True/False Separated Trophies, can cause very serious lag when scrolling Games! -->
    <sys:Boolean x:Key="SeparatedTrophies">False</sys:Boolean>



    <Color x:Key="BlackColor">#FF000000</Color>
    <Color x:Key="WhiteColor">#FFFFFFFF</Color>
    <Color x:Key="GlyphColor">Black</Color>
    <Color x:Key="GlyphLightColor">Black</Color>
    <Color x:Key="SelectionLightColor">#FF8D919D</Color>
    <Color x:Key="OverlayColor">#BB000000</Color>
    
    <Color x:Key="ControlBackgroundColor">#FF2B354D</Color>
    <Color x:Key="ControlBackgroundColorDark">#FF121830</Color>

    <Color x:Key="TextColor">#FFEBEBEB</Color>
    <Color x:Key="TextColorDark">#FF757575</Color>

    <SolidColorBrush x:Key="TextBrush" Color="{DynamicResource TextColor}" />
    <SolidColorBrush x:Key="TextBrushDark" Color="{DynamicResource TextColorDark}" />
    <SolidColorBrush x:Key="GlyphBrush" Color="{DynamicResource GlyphColor}" />
    <SolidColorBrush x:Key="GlyphLightBrush" Color="{DynamicResource GlyphLightColor}" />
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="{DynamicResource PS5Basic}" />
    <SolidColorBrush x:Key="ControlBackgroundDarkBrush" Color="{DynamicResource PS5Basic}" />
    <SolidColorBrush x:Key="SelectionLightBrush" Color="{DynamicResource SelectionLightColor}" />
    <SolidColorBrush x:Key="OverlayBrush" Color="{DynamicResource OverlayColor}" />
    <SolidColorBrush x:Key="CheckBoxCheckMarkBkBrush" Color="{DynamicResource ControlBackgroundColorDark}" />

    <sys:Double x:Key="FontSizeSmall">18</sys:Double>
    <sys:Double x:Key="FontSize">22</sys:Double>

    <sys:Double x:Key="FilterPanelWidth">450</sys:Double>
    
    <Style x:Key="TextBlockBaseStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource FontSize}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <RadialGradientBrush x:Key="MainBackgourndBrush" GradientOrigin="0.5,0.1" Center="0.5,0.2" RadiusX="0.5" RadiusY="0.7">
        <RadialGradientBrush.GradientStops>
            <GradientStop Color="Black" Offset="0" />
            <GradientStop Color="Black" Offset="1.0" />
        </RadialGradientBrush.GradientStops>
    </RadialGradientBrush>

    <LinearGradientBrush x:Key="TopBarBackgroundBrush" StartPoint="-0.5,0.5" EndPoint="1,0.5" >
        <GradientStop Color="#FF091F51" Offset="0"/>
        <GradientStop Color="#AA0B1027" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BottomBarBackgroundBrush" StartPoint="-0.5,0.5" EndPoint="1.5,1" >
        <GradientStop Color="#FF091F51" Offset="0"/>
        <GradientStop Color="#AA0B1027" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="OverlayMenuBackgroundBrush" StartPoint="0.5,0" EndPoint="0.5,1.5" >
        <GradientStop Color="#FF091F51" Offset="0"/>
        <GradientStop Color="#FF000623" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SelectionBrush" StartPoint="0.5,-0.5" EndPoint="1,1.5" >
        <GradientStop Color="{DynamicResource GlyphColor}" Offset="0"/>
        <GradientStop Color="{DynamicResource GlyphLightColor}" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GameDetailsBackgroundBrush" StartPoint="0.5,0" EndPoint="0.5,0.4" >
        <GradientStop Color="#00091F51" Offset="0.0"/>
        <GradientStop Color="#EE0B1027" Offset="0.8"/>
    </LinearGradientBrush>
    
    <SolidColorBrush x:Key="WarningBrush" Color="#ff6b6b" />

    <Style x:Key="SettingsSectionHeaderText" TargetType="TextBlock" BasedOn="{StaticResource TextBlockBaseStyle}">
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Margin" Value="0,15,0,10" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontFamily" Value="Segoe UI Bold"/>
        <Setter Property="Padding" Value="15,3,20,3" />
        <Setter Property="Height" Value="60"/>
        <Setter Property="Width" Value="990"/>
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="PS5Border" TargetType="Border">
        <Setter Property="BorderBrush">
            <Setter.Value>
                <LinearGradientBrush>
                    <GradientStop Color="{DynamicResource BorderDark}" Offset="0"/>
                    <GradientStop Color="{DynamicResource BorderLight}" Offset="1"/>
                    <LinearGradientBrush.RelativeTransform>
                        <RotateTransform CenterX="0.5" CenterY="0.5" x:Name="RotateBrush" />
                    </LinearGradientBrush.RelativeTransform>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Margin" Value="-6"/>
        <Setter Property="BorderThickness" Value="3"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True">
                <DataTrigger.EnterActions>
                    <BeginStoryboard Name="StartBorderBrush">
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" BeginTime="0:0:0.1" Duration="0:0:0.3" />
                            <DoubleAnimation Storyboard.TargetProperty="(Border.BorderBrush).(Brush.RelativeTransform).(RotateTransform.Angle)" 
											 From="0" To="359" Duration="00:00:4" RepeatBehavior="Forever" />
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.1" />
                        </Storyboard>
                    </BeginStoryboard>
                    <StopStoryboard BeginStoryboardName="StartBorderBrush" />
                </DataTrigger.ExitActions>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PS5Cover" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="Transparent" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="0.01"/>
                    <GradientStop Color="#50FFFFFF" Offset="0.3"/>
                    <GradientStop Color="Transparent" Offset="0.6"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True">
                <DataTrigger.EnterActions>
                    <BeginStoryboard Name="StartCoverFlash">
                        <Storyboard RepeatBehavior="Forever" Duration="0:0:5">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3" />
                            <DoubleAnimation
							Storyboard.TargetProperty="Background.(GradientBrush.GradientStops)[1].(GradientStop.Offset)"
							From="0.01" To="0.7" BeginTime="0:0:0" Duration="0:0:0.8" />
                            <DoubleAnimation
							Storyboard.TargetProperty="Background.(GradientBrush.GradientStops)[2].(GradientStop.Offset)"
							From="0.3" To="0.99" BeginTime="0:0:0" Duration="0:0:0.8" />
                            <DoubleAnimation
							Storyboard.TargetProperty="Background.(GradientBrush.GradientStops)[3].(GradientStop.Offset)"
							From="0.6" To="0.99" BeginTime="0:0:0" Duration="0:0:0.8" />
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" BeginTime="0:0:0.5" Duration="0:0:0.3" />
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="StartCoverFlash" />
                </DataTrigger.ExitActions>
            </DataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
